      "parameters": {
        "jsCode": "// Define se é PIX ou Cartão parcelado\nconst dados = $('Prepara Dados').first().json;\nconst buscou = $('Busca Cliente Asaas').first().json;\nconst criou = (() => { try { return $('Cria Cliente Asaas').first().json; } catch(e) { return null; } })();\nconst customerId = (buscou.data && buscou.data[0]) ? buscou.data[0].id : (criou ? criou.id : null);\nif (!customerId) throw new Error('Customer ID não encontrado');\nconst isPix = dados.paymentMethod !== 'cartao';\nconst dueDate = new Date(Date.now() + 24*60*60*1000).toISOString().split('T')[0];\nreturn [{\n  json: {\n    customerId,\n    cpf: dados.cpf,\n    billingType: isPix ? 'PIX' : 'CREDIT_CARD',\n    value: 49.90,\n    dueDate,\n    isPix,\n    // Para parcelamento\n    installmentCount: isPix ? 1 : 10,\n    installmentValue: isPix ? 49.90 : 4.90,\n    description: 'Acesso IRES Embaixadoras — Pagamento Único',\n    externalReference: dados.cpf\n  }\n}];"
      },
