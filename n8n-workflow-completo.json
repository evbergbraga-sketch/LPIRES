        "jsCode": "const lead = $('Valida Lead').first().json;\nconst cadastroUrl = 'https://evbergbraga-sketch.github.io/LPIRES/cadastro.html';\nconst wpp = '55' + lead.whatsapp.replace(/\\D/g, '') + '@s.whatsapp.net';\nconst cpfFormatado = lead.cpf.replace(/(\\d{3})(\\d{3})(\\d{3})(\\d{2})/, '$1.$2.$3-$4');\nconst msg = `Olá, *${lead.nome.split(' ')[0]}*! 🎉\\n\\nSeu pagamento foi confirmado!\\n\\nAgora é só criar sua senha e acessar a plataforma IRES Embaixadoras:\\n\\n👉 ${cadastroUrl}\\n\\nInforme o CPF *${cpfFormatado}* para liberar seu acesso.\\n\\nBem-vinda à família IRES! 🌸\\n\\n_IRES Embaixadoras_`;\nreturn [{ json: { wpp, msg, lead, cadastroUrl } }];"
